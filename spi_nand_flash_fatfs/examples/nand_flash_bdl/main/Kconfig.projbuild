menu "SPI NAND BDL example configuration"

    config EXAMPLE_FORMAT_IF_MOUNT_FAILED
        bool "Format the flash if mount failed"
        default n
        help
            If set, format_if_mount_failed is true and the volume is formatted when mount fails.

    config EXAMPLE_FORMAT_BEFORE_MOUNT
        bool "Format the volume before mount (explicit mkfs)"
        default n
        help
            If set, the example calls esp_vfs_fat_nand_bdl_format() with the same
            esp_vfs_fat_mount_config_t (allocation unit, FAT count) before esp_vfs_fat_bdl_mount().
            Use this to force a filesystem layout that matches your mount_config without relying on
            format_if_mount_failed.

endmenu
