CONFIG_ESP_TASK_WDT_INIT=n
CONFIG_SPIRAM=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
# Write core dumps to the dedicated flash partition during a panic.
# This is the no-OS path that must go through the dispatcher's real-op fallback.
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
