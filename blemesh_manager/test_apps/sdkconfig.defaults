# BLE Mesh Manager test app — sdkconfig defaults.
# The component's BLEMESH_MGR_ENABLE select-chain pulls in the BLE Mesh flags;
# these make the BT controller + Bluedroid config explicit so the component
# (and the esp_ble_mesh headers the tests include) build cleanly.
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_BLE_50_FEATURES_SUPPORTED=n

CONFIG_BLE_MESH=y
CONFIG_BLE_MESH_PROVISIONER=y
CONFIG_BLE_MESH_NODE=n
CONFIG_BLE_MESH_PB_ADV=y
CONFIG_BLE_MESH_PB_GATT=y
CONFIG_BLE_MESH_CFG_CLI=y
CONFIG_BLE_MESH_GENERIC_ONOFF_CLI=y
CONFIG_BLE_MESH_GENERIC_LEVEL_CLI=y
CONFIG_BLE_MESH_LIGHT_LIGHTNESS_CLI=y
CONFIG_BLE_MESH_LIGHT_CTL_CLI=y
CONFIG_BLE_MESH_LIGHT_HSL_CLI=y
CONFIG_BLE_MESH_SENSOR_CLI=y
CONFIG_BLE_MESH_SETTINGS=y
CONFIG_BLE_MESH_PROVISIONER_RECV_HB=y

CONFIG_BLEMESH_MGR_ENABLE=y
