menu "CANopenNode Stack Config"

    config CO_SDO_SERVER
        bool "Enable SDO server"
        default y
        help
            Enable the CANopen SDO server (CiA 301). Allows remote nodes and
            tools (e.g. PCAN-View, CANopen Magic) to read/write entries in
            the local Object Dictionary via SDO transfers. Includes support
            for expedited and segmented transfers (CO_SDOserver.c).

    config CO_SDO_CLIENT
        bool "Enable SDO client"
        default n
        help
            Enable the CANopen SDO client (CiA 301). Allows this node to
            initiate SDO uploads/downloads to other CANopen nodes. This adds
            the SDO client state machine and FIFO support needed by
            CO_SDOclient.c.

    config CO_MULTIPLE_OD
        bool "Enable MULTIPLE_OD"
        default false
        help
            Enable support for using application-specific CANopen object
            dictionary files (OD.c/OD.h) instead of a single default OD.
            When this option is enabled, the application or build system
            must provide the appropriate OD.c and OD.h files for each
            configuration that is built.

endmenu
