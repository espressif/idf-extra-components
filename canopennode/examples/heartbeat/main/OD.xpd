            <label lang="en">Event timer</label>
            <UINT />
            <q1:defaultValue value="200" />
          </q1:parameter>
          <q1:parameter uniqueID="UID_SUB_180006" access="readWrite">
            <label lang="en">SYNC start value</label>
            <USINT />
